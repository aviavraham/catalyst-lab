{
  "dashboard": {
    "annotations": {
      "list": [
        {
          "builtIn": 1,
          "datasource": {
            "type": "grafana",
            "uid": "-- Grafana --"
          },
          "enable": true,
          "hide": true,
          "iconColor": "rgba(0, 211, 255, 1)",
          "name": "Annotations & Alerts",
          "type": "dashboard"
        }
      ]
    },
    "panels": [
      {
        "datasource": {
          "type": "tempo",
          "uid": "tempo"
        },
        "gridPos": {
          "h": 10,
          "w": 24,
          "x": 0,
          "y": 0
        },
        "id": 1,
        "options": {
          "edges": {
            "mainStatUnit": "r/sec"
          },
          "nodes": {
            "arcs": [
              {
                "color": "red",
                "field": "arc__failed"
              },
              {
                "color": "green",
                "field": "arc__passed"
              }
            ],
            "mainStatUnit": "ms"
          }
        },
        "targets": [
          {
            "datasource": {
              "type": "tempo",
              "uid": "tempo"
            },
            "queryType": "serviceMap",
            "serviceMapQuery": "{}"
          }
        ],
        "title": "Service Graph",
        "type": "nodeGraph"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 20,
              "lineInterpolation": "smooth",
              "pointSize": 5,
              "spanNulls": true
            },
            "unit": "reqps"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 10
        },
        "id": 2,
        "options": {
          "tooltip": {
            "mode": "multi"
          }
        },
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "sum(rate(traces_service_graph_request_total{client=~\".*_agent\"}[5m])) by (client)",
            "legendFormat": "{{client}}"
          }
        ],
        "title": "Agent Request Rate (5m)",
        "type": "timeseries"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "fillOpacity": 10,
              "pointSize": 5,
              "spanNulls": true
            },
            "unit": "s"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 10
        },
        "id": 3,
        "options": {
          "tooltip": {
            "mode": "multi"
          }
        },
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "histogram_quantile(0.50, sum(rate(traces_spanmetrics_latency_bucket{service=\"llamastack\", span_name=~\"chat.*\"}[5m])) by (le))",
            "legendFormat": "P50"
          },
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "histogram_quantile(0.95, sum(rate(traces_spanmetrics_latency_bucket{service=\"llamastack\", span_name=~\"chat.*\"}[5m])) by (le))",
            "legendFormat": "P95"
          },
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "histogram_quantile(0.99, sum(rate(traces_spanmetrics_latency_bucket{service=\"llamastack\", span_name=~\"chat.*\"}[5m])) by (le))",
            "legendFormat": "P99"
          }
        ],
        "title": "LLM Inference Latency (P50 / P95 / P99)",
        "type": "timeseries"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 10
                },
                {
                  "color": "red",
                  "value": 50
                }
              ]
            },
            "unit": "short"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 8,
          "x": 0,
          "y": 18
        },
        "id": 4,
        "options": {
          "displayMode": "gradient",
          "orientation": "horizontal",
          "reduceOptions": {
            "calcs": [
              "lastNotNull"
            ]
          }
        },
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "sum(increase(traces_service_graph_request_total[1h])) by (client, server)",
            "legendFormat": "{{client}} \u2192 {{server}}"
          }
        ],
        "title": "Service Graph Request Rates",
        "type": "bargauge"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {
                  "color": "red",
                  "value": null
                },
                {
                  "color": "yellow",
                  "value": 3
                },
                {
                  "color": "green",
                  "value": 5
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 8,
          "y": 18
        },
        "id": 5,
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "textMode": "value_and_name"
        },
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "count(count(traces_spanmetrics_calls_total) by (service))"
          }
        ],
        "title": "Active Agent Services",
        "type": "stat"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "steps": [
                {
                  "color": "blue",
                  "value": null
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 12,
          "y": 18
        },
        "id": 6,
        "options": {
          "colorMode": "background",
          "graphMode": "area"
        },
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "sum(increase(traces_spanmetrics_calls_total{service=\"llamastack\", span_name=~\"chat.*\"}[1h]))"
          }
        ],
        "title": "Total LLM Calls (1h)",
        "type": "stat"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "noValue": "0",
            "thresholds": {
              "steps": [
                {
                  "color": "green",
                  "value": null
                },
                {
                  "color": "red",
                  "value": 1
                }
              ]
            }
          }
        },
        "gridPos": {
          "h": 4,
          "w": 4,
          "x": 16,
          "y": 18
        },
        "id": 7,
        "options": {
          "colorMode": "background",
          "graphMode": "none"
        },
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "sum(increase(traces_service_graph_request_failed_total[1h]))"
          }
        ],
        "title": "Error Rate",
        "type": "stat"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "s"
          },
          "overrides": [
            {
              "matcher": {
                "id": "byName",
                "options": "Time"
              },
              "properties": [
                {
                  "id": "custom.hidden",
                  "value": true
                }
              ]
            },
            {
              "matcher": {
                "id": "byName",
                "options": "le"
              },
              "properties": [
                {
                  "id": "custom.hidden",
                  "value": true
                }
              ]
            }
          ]
        },
        "gridPos": {
          "h": 8,
          "w": 4,
          "x": 20,
          "y": 18
        },
        "id": 8,
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "histogram_quantile(0.50, sum(rate(traces_service_graph_request_server_seconds_bucket[5m])) by (le, client, server))",
            "format": "table",
            "instant": true
          }
        ],
        "title": "Service-to-Service Latency (P50)",
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "__name__": true,
                "le": true
              }
            }
          }
        ],
        "type": "table"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "bars",
              "fillOpacity": 80,
              "stacking": {
                "mode": "normal"
              }
            },
            "unit": "ops"
          }
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 26
        },
        "id": 9,
        "targets": [
          {
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            },
            "expr": "sum(rate(traces_spanmetrics_calls_total{span_name=~\"invoke_agent.*|execute_tool.*|call_llm.*|generate_content.*\"}[5m])) by (service, span_name)",
            "legendFormat": "{{service}} / {{span_name}}"
          }
        ],
        "title": "Agent Span Counts by Operation",
        "type": "timeseries"
      },
      {
        "datasource": {
          "type": "tempo",
          "uid": "tempo"
        },
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 26
        },
        "id": 10,
        "targets": [
          {
            "datasource": {
              "type": "tempo",
              "uid": "tempo"
            },
            "limit": 20,
            "query": "{} | select(resource.service.name, name, duration, status)",
            "queryType": "traceqlSearch"
          }
        ],
        "title": "Recent Traces",
        "type": "table"
      }
    ],
    "refresh": "30s",
    "tags": [
      "catalyst-lab",
      "agents",
      "llm"
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timezone": "utc",
    "title": "AI Catalyst Lab Overview",
    "uid": "catalyst-lab-overview"
  },
  "overwrite": true,
  "folderId": 0
}
